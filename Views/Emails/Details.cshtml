@using Microsoft.AspNetCore.Http.Extensions
@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer
@model MailArchiver.Models.ViewModels.EmailDetailViewModel
@{
    ViewData["Title"] = @Localizer["EmailDetails"];
    var returnUrl = ViewBag.ReturnUrl?.ToString() ?? Url.Action("Index");
}

<div class="container-fluid">
    <div
        class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-3 gap-2">
        <h1 class="h3 mb-0">@Localizer["EmailDetails"]</h1>

        <!-- Mobile Button Layout -->
        <div class="d-md-none w-100">
            <div class="d-grid gap-2">
                <a href="@returnUrl" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> @Localizer["BackToList"]
                </a>
                <a href="#" class="btn btn-outline-info btn-sm" id="replyButtonMobile" onclick="handleReplyClick(event)">
                    <i class="bi bi-arrow-return-left"></i> @Localizer["Reply"]
                </a>
                <a asp-action="Export" asp-route-id="@Model.Email.Id" asp-route-format="Eml"
                    class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-envelope"></i> @Localizer["ExportEML"]
                </a>
                <a asp-action="Restore" asp-route-id="@Model.Email.Id"
                    asp-route-returnUrl="@Context.Request.GetDisplayUrl()" class="btn btn-success btn-sm">
                    <i class="bi bi-envelope-arrow-up"></i> @Localizer["CopyToMailbox"]
                </a>
                @if (User.IsInRole("Admin") || User.IsInRole("SelfManager"))
                {
                    <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteEmailModal">
                        <i class="bi bi-trash"></i> @Localizer["DeleteEmail"]
                    </button>
                }
            </div>
        </div>

        <!-- Desktop Button Layout -->
        <div class="d-none d-md-flex gap-2">
            <a href="@returnUrl" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> @Localizer["BackToList"]
            </a>
            <a href="#" class="btn btn-outline-info" id="replyButton" data-bs-toggle="tooltip" title="@Localizer["Reply"]" onclick="handleReplyClick(event)">
                <i class="bi bi-arrow-return-left"></i>
            </a>
            <a asp-action="Export" asp-route-id="@Model.Email.Id" asp-route-format="Eml"
                class="btn btn-outline-primary">
                <i class="bi bi-envelope"></i> @Localizer["ExportEML"]
            </a>
            <a asp-action="Restore" asp-route-id="@Model.Email.Id"
                asp-route-returnUrl="@Context.Request.GetDisplayUrl()" class="btn btn-success">
                <i class="bi bi-envelope-arrow-up"></i> @Localizer["CopyToMailbox"]
            </a>
            @if (User.IsInRole("Admin") || User.IsInRole("SelfManager"))
            {
                <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteEmailModal">
                    <i class="bi bi-trash"></i> @Localizer["DeleteEmail"]
                </button>
            }
        </div>
    </div>

    <!-- Rest of the view remains the same -->
    <div class="card mb-3">
        <div class="card-header bg-light">
            <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center gap-2">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    @if (Model.Email.IsOutgoing)
                    {
                        <span class="badge bg-info fs-6">@Localizer["Outgoing"]</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary fs-6">@Localizer["Incoming"]</span>
                    }
                    @if (Model.Email.HasAttachments)
                    {
                        <span class="badge bg-warning text-dark">
                            <i class="bi bi-paperclip"></i> @Localizer["Attachments"]
                        </span>
                    }
                </div>
                <h5 class="mb-0 flex-grow-1">@Model.Email.Subject</h5>
            </div>
        </div>

        <!-- Rest of the email content display remains unchanged -->
        <div class="card-body">
            <!-- Email Meta Information in Mobile-friendly format -->
            <div class="row g-2 mb-2">
                <div class="col-12 col-md-2">
                    <strong class="text-muted small">@Localizer["Account"]:</strong>
                </div>
                <div class="col-12 col-md-10">
                    <span class="badge bg-light text-dark border">@Model.AccountName</span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Email.FolderName))
            {
                <div class="row g-2 mb-2">
                    <div class="col-12 col-md-2">
                        <strong class="text-muted small">@Localizer["Folder"]:</strong>
                    </div>
                    <div class="col-12 col-md-10">
                        <span class="badge bg-light text-dark border">@Model.Email.FolderName</span>
                    </div>
                </div>
            }

            <div class="row g-2 mb-2">
                <div class="col-12 col-md-2">
                    <strong class="text-muted small">@Localizer["From"]:</strong>
                </div>
                <div class="col-12 col-md-10">
                    <span class="email-text-break text-dark">@Model.Email.From</span>
                </div>
            </div>

            <div class="row g-2 mb-2">
                <div class="col-12 col-md-2">
                    <strong class="text-muted small">@Localizer["To"]:</strong>
                </div>
                <div class="col-12 col-md-10">
                    <span class="email-text-break text-dark">@Model.Email.To</span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Email.Cc))
            {
                <div class="row g-2 mb-2">
                    <div class="col-12 col-md-2">
                        <strong class="text-muted small">CC:</strong>
                    </div>
                    <div class="col-12 col-md-10">
                        <span class="email-text-break text-dark">@Model.Email.Cc</span>
                    </div>
                </div>
            }

            <div class="row g-2 mb-3">
                <div class="col-12 col-md-2">
                    <strong class="text-muted small">@Localizer["Date"]:</strong>
                </div>
                <div class="col-12 col-md-10">
                    @Model.Email.SentDate.ToString(System.Globalization.CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern + " " + System.Globalization.CultureInfo.CurrentUICulture.DateTimeFormat.ShortTimePattern)
                </div>
            </div>

            @if (Model.Email.Attachments.Any())
            {
                <div class="row g-2 mb-3">
                    <div class="col-12 col-md-2">
                        <strong class="text-muted small">@Localizer["Attachments"]:</strong>
                    </div>
                    <div class="col-12 col-md-10">
                        <!-- Mobile: Stacked attachment list -->
                        <div class="d-md-none d-grid gap-2 mobile-attachments">
                            @foreach (var attachment in Model.Email.Attachments)
                            {
                                <button type="button" 
                                    class="btn btn-outline-secondary btn-sm text-start d-flex justify-content-between align-items-center attachment-preview-btn"
                                    data-email-id="@Model.Email.Id"
                                    data-attachment-id="@attachment.Id"
                                    data-filename="@attachment.FileName"
                                    data-content-type="@attachment.ContentType"
                                    data-download-url="@Url.Action("Attachment", new { emailId = Model.Email.Id, attachmentId = attachment.Id })"
                                    data-preview-url="@Url.Action("AttachmentPreview", new { emailId = Model.Email.Id, attachmentId = attachment.Id })">
                                    <span class="text-truncate me-2">
                                        <i class="bi bi-paperclip me-1"></i>@attachment.FileName
                                    </span>
                                    <span class="badge bg-primary">@FormatFileSize(attachment.Size)</span>
                                </button>
                            }
                        </div>
                        <!-- Desktop: List group -->
                        <div class="d-none d-md-block">
                            <div class="list-group">
                                @foreach (var attachment in Model.Email.Attachments)
                                {
                                    <button type="button"
                                        class="list-group-item list-group-item-action d-flex justify-content-between align-items-center attachment-preview-btn"
                                        data-email-id="@Model.Email.Id"
                                        data-attachment-id="@attachment.Id"
                                        data-filename="@attachment.FileName"
                                        data-content-type="@attachment.ContentType"
                                        data-download-url="@Url.Action("Attachment", new { emailId = Model.Email.Id, attachmentId = attachment.Id })"
                                        data-preview-url="@Url.Action("AttachmentPreview", new { emailId = Model.Email.Id, attachmentId = attachment.Id })">
                                        <span><i class="bi bi-paperclip me-2"></i>@attachment.FileName</span>
                                        <span class="badge bg-primary rounded-pill">@FormatFileSize(attachment.Size)</span>
                                    </button>
                                }
                            </div>
                        </div>
                        <!-- Download all attachments button -->
                        <div class="mt-2">
                            <a asp-action="DownloadAllAttachments" asp-route-id="@Model.Email.Id" class="btn btn-primary btn-sm">
                                <i class="bi bi-download"></i> @Localizer["DownloadAllAttachments"]
                            </a>
                        </div>
                    </div>
                </div>
            }

            <hr />

            <!-- Email Content -->
            <div class="email-content mt-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0 text-muted">@Localizer["EmailContent"]</h6>
                    <div class="btn-group" role="group">
                        @* Show toggle button only if both HTML and plain text are available *@
                        @if (Model.HasHtmlBody && Model.HasPlainTextBody)
                        {
                            <button type="button" id="view-toggle-btn" class="btn btn-outline-primary btn-sm" onclick="toggleEmailView()">
                                <i class="bi bi-file-text"></i>
                                <span id="toggle-btn-text">@(Model.DefaultToPlainText ? Localizer["ShowHtml"] : Localizer["ShowPlainText"])</span>
                            </button>
                        }
                        <a id="full-view-link" asp-action="RawContent" asp-route-id="@Model.Email.Id" asp-route-plainText="@(Model.DefaultToPlainText ? "true" : "false")" target="_blank"
                            class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrows-fullscreen"></i>
                            <span class="d-none d-sm-inline">@Localizer["FullView"]</span>
                        </a>
                    </div>
                </div>

                @* HTML View Container *@
                @if (Model.HasHtmlBody)
                {
                    <div id="html-view-container" class="email-content-container" style="min-height: 800px; display: @(Model.DefaultToPlainText && Model.HasPlainTextBody ? "none" : "block");">
                        <iframe id="email-content-frame" src="@Url.Action("RawContent", new { id = Model.Email.Id })"
                            class="w-100 border rounded email-iframe" sandbox="allow-popups allow-downloads allow-scripts" style="min-height: 800px; height: 800px; max-height: 1200px;"></iframe>
                    </div>
                }

                @* Plain Text View Container *@
                @if (Model.HasPlainTextBody)
                {
                    <div id="text-view-container" class="border rounded p-3 bg-light" style="display: @(Model.DefaultToPlainText || !Model.HasHtmlBody ? "block" : "none");">
                        <pre class="mb-0 email-text-content" style="white-space: pre-wrap; word-wrap: break-word;">@Model.PlainTextBody</pre>
                    </div>
                }

                @* Fallback if neither HTML nor plain text is available *@
                @if (!Model.HasHtmlBody && !Model.HasPlainTextBody)
                {
                    <div class="border rounded p-3 bg-light text-muted">
                        <p class="mb-0">@Localizer["EmailContent"] not available</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Delete Email Modal -->
@if (User.IsInRole("Admin") || User.IsInRole("SelfManager"))
{
    <div class="modal fade" id="deleteEmailModal" tabindex="-1" aria-labelledby="deleteEmailModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteEmailModalLabel">@Localizer["ConfirmDeletion"]</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>@Localizer["DeleteEmailConfirm"]</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                    <form asp-action="Delete" asp-route-id="@Model.Email.Id" asp-route-returnUrl="@returnUrl" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">@Localizer["DeleteButton"]</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<!-- Attachment Preview Modal -->
<div class="modal fade" id="attachmentPreviewModal" tabindex="-1" aria-labelledby="attachmentPreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="attachmentPreviewModalLabel">@Localizer["AttachmentPreview"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 id="previewFileName" class="mb-0"></h6>
                    <a id="downloadAttachmentBtn" class="btn btn-primary" href="">
                        <i class="bi bi-download"></i> @Localizer["Download"]
                    </a>
                </div>
                <div id="previewContent" class="text-center" style="min-height: 400px; max-height: 70vh; overflow: auto;">
                    <div class="d-flex justify-content-center align-items-center h-100">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> @Localizer["Close"]
                </button>
                <a id="downloadAttachmentBtnFooter" class="btn btn-primary" href="">
                    <i class="bi bi-download"></i> @Localizer["Download"]
                </a>
            </div>
        </div>
    </div>
</div>


<script>
    // Securely pass email reply data to JavaScript as JSON (prevents XSS via data-* attributes)
    window.emailReplyData = {
        sender: @Json.Serialize(Model.Email.From),
        subject: @Json.Serialize(Model.Email.Subject),
        sentDate: @Json.Serialize(Model.Email.SentDate.ToString("yyyy-MM-dd HH:mm")),
        body: @Json.Serialize(Model.Email.Body)
    };

    // Localized strings for JavaScript
    const localizedStrings = {
        previewNotAvailable: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PreviewNotAvailable"].Value)),
        fileTypeCannotBePreviewed: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["FileTypeCannotBePreviewed"].Value)),
        showPlainText: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ShowPlainText"].Value)),
        showHtml: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ShowHtml"].Value))
    };

    // Track current view state (true = HTML, false = plain text)
    let isShowingHtml = @(Model.DefaultToPlainText && Model.HasPlainTextBody ? "false" : "true");

    // Function to toggle between HTML and plain text views
    function toggleEmailView() {
        const htmlContainer = document.getElementById('html-view-container');
        const textContainer = document.getElementById('text-view-container');
        const toggleBtn = document.getElementById('view-toggle-btn');
        const toggleBtnText = document.getElementById('toggle-btn-text');
        const fullViewLink = document.getElementById('full-view-link');

        if (isShowingHtml) {
            // Switch to plain text
            if (htmlContainer) htmlContainer.style.display = 'none';
            if (textContainer) textContainer.style.display = 'block';
            if (toggleBtnText) toggleBtnText.textContent = localizedStrings.showHtml;
            // Update Full View link to use plain text
            if (fullViewLink) {
                const url = new URL(fullViewLink.href);
                url.searchParams.set('plainText', 'true');
                fullViewLink.href = url.toString();
            }
            isShowingHtml = false;
        } else {
            // Switch to HTML
            if (htmlContainer) htmlContainer.style.display = 'block';
            if (textContainer) textContainer.style.display = 'none';
            if (toggleBtnText) toggleBtnText.textContent = localizedStrings.showPlainText;
            // Update Full View link to use HTML
            if (fullViewLink) {
                const url = new URL(fullViewLink.href);
                url.searchParams.set('plainText', 'false');
                fullViewLink.href = url.toString();
            }
            isShowingHtml = true;
        }
    }

    // Function to format email body for reply (prefix each line with "> ")
    function formatReplyBody(body) {
        if (!body) return '';
        
        // Split into lines, prefix each line with "> ", and join back
        return body.split('\n').map(line => `> ${line}`).join('\n');
    }

    // Function to handle reply button click
    function handleReplyClick(event) {
        event.preventDefault();
        
        // Get data from the secure JSON object rendered by the server
        const sender = window.emailReplyData.sender;
        const subject = window.emailReplyData.subject;
        const sentDate = window.emailReplyData.sentDate;
        const originalBody = window.emailReplyData.body || "[Original content not available]";
        
        // Format the body with ">" prefix for each line
        let formattedBody = formatReplyBody(originalBody);
        
        // Add the header information
        const replyHeader = `On ${sentDate}, ${sender} wrote:\n\n`;
        const fullBody = replyHeader + formattedBody;
        
        // Check size limitations (mailto URLs typically have ~2000 character limit)
        const maxBodyLength = 1500; // Conservative limit to account for other URL parts
        let finalBody = fullBody;
        if (fullBody.length > maxBodyLength) {
            // Truncate and add notice
            finalBody = fullBody.substring(0, maxBodyLength - 100) + "\n\n[Message truncated due to size limitations]";
        }
        
        // Create and trigger mailto link
        const mailtoUrl = `mailto:${sender}?subject=${encodeURIComponent("Re: " + subject)}&body=${encodeURIComponent(finalBody)}`;
        
        // Check if URL is too long
        if (mailtoUrl.length > 1800) {
            console.warn('Mailto URL is very long and may exceed browser/email client limits');
        }
        
        window.location.href = mailtoUrl;
    }

    // Handle mobile reply button click
    document.addEventListener('DOMContentLoaded', function () {
        const mobileReplyButton = document.getElementById('replyButtonMobile');
        if (mobileReplyButton) {
            mobileReplyButton.addEventListener('click', function(e) {
                e.preventDefault();
                handleReplyClick(e);
            });
        }

        // Attachment preview functionality
        const previewButtons = document.querySelectorAll('.attachment-preview-btn');
        const previewModal = new bootstrap.Modal(document.getElementById('attachmentPreviewModal'));
        const previewContent = document.getElementById('previewContent');
        const previewFileName = document.getElementById('previewFileName');
        const downloadBtn = document.getElementById('downloadAttachmentBtn');
        const downloadBtnFooter = document.getElementById('downloadAttachmentBtnFooter');

        previewButtons.forEach(button => {
            button.addEventListener('click', function () {
                const emailId = this.getAttribute('data-email-id');
                const attachmentId = this.getAttribute('data-attachment-id');
                const fileName = this.getAttribute('data-filename');
                const contentType = this.getAttribute('data-content-type');
                const downloadUrl = this.getAttribute('data-download-url');
                const previewUrl = this.getAttribute('data-preview-url');

                // Set file name in modal header
                previewFileName.textContent = fileName;

                // Set download links
                downloadBtn.href = downloadUrl;
                downloadBtnFooter.href = downloadUrl;

                // Show loading spinner
                previewContent.innerHTML = '<div class="d-flex justify-content-center align-items-center h-100"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>';

                // Show modal
                previewModal.show();

                // Determine how to display based on content type
                if (contentType.startsWith('image/')) {
                    // Display image directly
                    previewContent.innerHTML = `<img src="${previewUrl}" class="img-fluid" alt="${fileName}" style="max-height: 70vh;">`;
                } else if (contentType === 'application/pdf') {
                    // Display PDF using iframe
                    previewContent.innerHTML = `<iframe src="${previewUrl}" type="application/pdf" width="100%" height="600px" />`;
                } else if (contentType.startsWith('text/')) {
                    // Display text files
                    fetch(previewUrl)
                        .then(response => response.text())
                        .then(text => {
                            previewContent.innerHTML = `<pre class="text-start" style="white-space: pre-wrap; max-height: 70vh; overflow: auto;">${escapeHtml(text)}</pre>`;
                        })
                        .catch(error => {
                            previewContent.innerHTML = `<div class="alert alert-danger">Error loading file: ${error.message}</div>`;
                        });
                } else {
                    // For other file types, show download prompt
                    previewContent.innerHTML = `
                        <div class="d-flex flex-column align-items-center justify-content-center h-100">
                            <i class="bi bi-file-earmark-arrow-down" style="font-size: 4rem;"></i>
                            <h5 class="mt-3">${localizedStrings.previewNotAvailable}</h5>
                            <p>${localizedStrings.fileTypeCannotBePreviewed}</p>
                        </div>
                    `;
                }
            });
        });

        // Helper function to escape HTML
        function escapeHtml(text) {
            const map = {
                '&': '&',
                '<': '<',
                '>': '>',
                '"': '"',
                "'": '&#039;'
            };
            
            return text.replace(/[&<>"']/g, function(m) { return map[m]; });
        }
    });
</script>

@functions {
    string FormatFileSize(long bytes)
    {
        string[] suffixes = { "B", "KB", "MB", "GB", "TB" };
        int counter = 0;
        decimal number = bytes;
        while (Math.Round(number / 1024) >= 1)
        {
            number /= 1024;
            counter++;
        }
        return $"{number:n1} {suffixes[counter]}";
    }
}
