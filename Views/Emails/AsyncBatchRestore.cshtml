@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer
@model MailArchiver.Models.ViewModels.AsyncBatchRestoreViewModel
@{
    ViewData["Title"] = Localizer["AsynchronousBatchCopyTitle"];
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>@Localizer["AsynchronousBatchCopyTitle"]</h1>
        <a href="@(string.IsNullOrEmpty(Model.ReturnUrl) ? Url.Action("Index") : Model.ReturnUrl)"
            class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> @Localizer["Back"]
        </a>
    </div>

    @if (ViewBag.EmailCount != null && ViewBag.EmailCount > 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle-fill me-2"></i>
            <strong>@Localizer["BenefitsHeader"]</strong>
            <ul class="mb-0 mt-2">
                <li>@Localizer["BenefitRunsInBackground"]</li>
                <li>@Localizer["BenefitMonitorRealtime"]</li>
                <li>@Localizer["BenefitCanCancel"]</li>
                <li>@Localizer["BenefitNoTimeout"]</li>
                <li>@Localizer["BenefitAutoRetry"]</li>
            </ul>
        </div>
    }

    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">@Localizer["TargetSettings"]</h5>
        </div>
        <div class="card-body">
            <form asp-action="StartAsyncBatchRestore" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                @foreach (var id in Model.EmailIds)
                {
                    <input type="hidden" name="EmailIds" value="@id" />
                }
                <input type="hidden" asp-for="ReturnUrl" />
                <div class="mb-3">
                    <label asp-for="TargetAccountId" class="form-label">@Localizer["TargetAccount"]</label>
                    <select asp-for="TargetAccountId" asp-items="Model.AvailableAccounts" 
                            class="form-select" id="accountSelect">
                        <option value=""> @Localizer["SelectAccount"] </option>
                    </select>
                    <span asp-validation-for="TargetAccountId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="TargetFolder" class="form-label">@Localizer["TargetFolder"]</label>
                    <select asp-for="TargetFolder" class="form-select" id="folderSelect">
                        @if (Model.AvailableFolders != null && Model.AvailableFolders.Any())
                        {
                            @foreach (var folder in Model.AvailableFolders)
                            {
                                <option value="@folder.Value" selected="@folder.Selected">@folder.Text</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="TargetFolder" class="text-danger"></span>
                </div>
                <div class="mb-3 form-check">
                    <input asp-for="PreserveFolderStructure" class="form-check-input" type="checkbox" id="preserveFolderStructure" />
                    <label asp-for="PreserveFolderStructure" class="form-check-label">@Localizer["PreserveFolderStructure"]</label>
                    <div class="form-text">
                        @Localizer["PreserveFolderStructureHelp"]
                    </div>
                </div>
                <div class="d-flex mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-clock me-2"></i>@Localizer["StartBackgroundOperation"]
                    </button>
                    <a href="@(string.IsNullOrEmpty(Model.ReturnUrl) ? Url.Action("Index") : Model.ReturnUrl)"
                        class="btn btn-outline-secondary ms-2">
                        @Localizer["Cancel"]
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function () {
            var preselectedFolder = @Json.Serialize(Model.TargetFolder ?? "");
            var isInitialLoad = true;
            const i18n = {
                loadingFolders: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["LoadingFolders"].Value)),
                errorLoadingFolders: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ErrorLoadingFolders"].Value))
            };
            $('#accountSelect').change(function () {
                var selectPreselected = isInitialLoad;
                isInitialLoad = false;
                var accountId = $(this).val();
                if (accountId) {
                    $('#folderSelect').html($('<option>').text(i18n.loadingFolders));
                    $.ajax({
                        url: '@Url.Action("GetFolders", "Emails")',
                        data: { accountId: accountId },
                        type: 'GET',
                        dataType: 'json',
                        success: function (data) {
                            var options = '';
                            var inboxFound = false;
                            $.each(data, function (index, folderName) {
                                options += '<option value="' + folderName + '">' + folderName + '</option>';
                                if (folderName.toUpperCase() === 'INBOX') { inboxFound = true; }
                            });
                            $('#folderSelect').html(options);
                            var target = (selectPreselected && preselectedFolder) ? preselectedFolder : null;
                            var matched = target ? $("#folderSelect option").filter(function () { return this.value.toUpperCase() === target.toUpperCase(); }).first() : $();
                            if (matched.length) { matched.prop('selected', true); }
                            else if (inboxFound) { $("#folderSelect option").filter(function () { return this.value.toUpperCase() === 'INBOX'; }).prop('selected', true); }
                        },
                        error: function () {
                            $('#folderSelect').html($('<option>').val('').text(i18n.errorLoadingFolders)).append('<option value="INBOX">INBOX</option>');
                        }
                    });
                } else {
                    $('#folderSelect').html('');
                }
            });
            if ($('#accountSelect').val()) { $('#accountSelect').trigger('change'); }
        });
    </script>
}
