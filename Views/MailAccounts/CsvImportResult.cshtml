@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer
@model MailArchiver.Models.ViewModels.CsvImportResultViewModel
@{
    ViewData["Title"] = Localizer["CsvImportResult"];
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">@Localizer["CsvImportResult"]</h1>
        <div class="d-flex gap-2">
            <a asp-action="ImportCsv" class="btn btn-primary btn-sm">
                <i class="bi bi-upload"></i> @Localizer["CsvImportAgain"]
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> @Localizer["BackToAccounts"]
            </a>
        </div>
    </div>

    <div class="alert @((Model.FailedCount > 0 && Model.CreatedCount == 0) ? "alert-danger" : (Model.FailedCount > 0 ? "alert-warning" : "alert-success"))">
        <h5 class="mb-2">
            <i class="bi @(Model.CreatedCount > 0 ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-2"></i>
            @Localizer["CsvImportResultSummary", Model.CreatedCount, Model.SkippedCount, Model.FailedCount]
        </h5>
        <div class="row text-center mt-3">
            <div class="col-md-4 mb-2">
                <div class="badge bg-success p-3 w-100">
                    <div class="h4 mb-0">@Model.CreatedCount</div>
                    <small>@Localizer["CsvImportCreated"]</small>
                </div>
            </div>
            <div class="col-md-4 mb-2">
                <div class="badge bg-warning text-dark p-3 w-100">
                    <div class="h4 mb-0">@Model.SkippedCount</div>
                    <small>@Localizer["CsvImportSkipped"]</small>
                </div>
            </div>
            <div class="col-md-4 mb-2">
                <div class="badge bg-danger p-3 w-100">
                    <div class="h4 mb-0">@Model.FailedCount</div>
                    <small>@Localizer["CsvImportFailed"]</small>
                </div>
            </div>
        </div>
    </div>

    @if (Model.CreatedRows.Any())
    {
        <div class="card mb-3">
            <div class="card-header bg-light d-flex align-items-center justify-content-between">
                <span class="h6 mb-0"><i class="bi bi-check-circle text-success me-2"></i>@Localizer["CsvImportCreated"]</span>
                <span class="badge bg-success">@Model.CreatedRows.Count</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-sm mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>@Localizer["CsvImportEmail"]</th>
                                <th>@Localizer["CsvImportNameCol"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.CreatedRows)
                            {
                                <tr>
                                    <td>@row.Email</td>
                                    <td>@row.Name</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (Model.SkippedRows.Any())
    {
        <div class="card mb-3">
            <div class="card-header bg-light d-flex align-items-center justify-content-between">
                <span class="h6 mb-0"><i class="bi bi-skip-forward text-warning me-2"></i>@Localizer["CsvImportSkipped"]</span>
                <span class="badge bg-warning text-dark">@Model.SkippedRows.Count</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-sm mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>@Localizer["CsvImportEmail"]</th>
                                <th>@Localizer["CsvImportReason"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.SkippedRows)
                            {
                                <tr>
                                    <td>@row.Email</td>
                                    <td>@row.Reason</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (Model.FailedRows.Any())
    {
        <div class="card mb-3">
            <div class="card-header bg-light d-flex align-items-center justify-content-between">
                <span class="h6 mb-0"><i class="bi bi-x-circle text-danger me-2"></i>@Localizer["CsvImportFailed"]</span>
                <span class="badge bg-danger">@Model.FailedRows.Count</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-sm mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 80px;">@Localizer["CsvImportRowNumber"]</th>
                                <th>@Localizer["CsvImportEmail"]</th>
                                <th>@Localizer["CsvImportReason"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.FailedRows)
                            {
                                <tr>
                                    <td>@(row.LineNumber > 0 ? row.LineNumber.ToString() : "-")</td>
                                    <td>@(string.IsNullOrEmpty(row.Email) ? "-" : row.Email)</td>
                                    <td>@row.Reason</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>